@echo off
title Warden's Debt
echo ======================================================
echo  Warden's Debt - Starting local web server
echo ======================================================
echo.

set "ROOT=%~dp0"

REM Serve from this folder so WardensDebt\ is reachable as /WardensDebt/.
cd /d "%ROOT%"

REM Try Python 3 via the py launcher.
py --version >nul 2>&1
if %errorlevel%==0 (
    echo Found Python ^(py launcher^).
    echo Opening http://localhost:8080/WardensDebt/ in your browser...
    timeout /t 1 /nobreak >nul
    start "" http://localhost:8080/WardensDebt/
    py -m http.server 8080
    goto :done
)

REM Try python3.
python3 --version >nul 2>&1
if %errorlevel%==0 (
    echo Found Python 3.
    echo Opening http://localhost:8080/WardensDebt/ in your browser...
    timeout /t 1 /nobreak >nul
    start "" http://localhost:8080/WardensDebt/
    python3 -m http.server 8080
    goto :done
)

REM Try plain python.
python --version >nul 2>&1
if %errorlevel%==0 (
    echo Found Python.
    echo Opening http://localhost:8080/WardensDebt/ in your browser...
    timeout /t 1 /nobreak >nul
    start "" http://localhost:8080/WardensDebt/
    python -m http.server 8080
    goto :done
)

REM Try the built-in PowerShell listener fallback.
where powershell >nul 2>&1
if %errorlevel%==0 goto :serve_powershell

REM Try Node / npx as a last resort.
npx --version >nul 2>&1
if %errorlevel%==0 (
    echo Found Node.js / npx.
    echo Opening http://localhost:3000/WardensDebt/ in your browser...
    timeout /t 2 /nobreak >nul
    start "" http://localhost:3000/WardensDebt/
    npx serve .
    goto :done
)

REM No supported server tool was found.
echo.
echo ERROR: Could not find Python, PowerShell, or Node.js on this machine.
echo.
echo To fix this, do ONE of the following:
echo.
echo   Option A  Install Python from https://www.python.org
echo             (free, takes ~5 minutes)
echo             Then double-click start.bat again.
echo.
echo   Option B  Open index.html with Mozilla Firefox.
echo             Firefox can run the page without a server.
echo.
pause
goto :done

:serve_powershell
echo Found PowerShell.
echo Opening http://localhost:8080/WardensDebt/ in your browser...
timeout /t 1 /nobreak >nul
start "" http://localhost:8080/WardensDebt/
powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand  "%ROOT%"
goto :done

:done

